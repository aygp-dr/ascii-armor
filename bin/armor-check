#!/bin/sh
# armor-check: Validate encoded files round-trip correctly
# Usage: armor-check [file...]
# Exit: 0 if all pass, 1 if any fail

set -e

PASS=0
FAIL=0
SKIP=0

check_file() {
    file="$1"
    ext="${file##*.}"
    base="${file%.*}"
    tmpdir=$(mktemp -d)
    trap "rm -rf $tmpdir" EXIT

    case "$ext" in
        uu)
            if command -v uudecode >/dev/null 2>&1; then
                (cd "$tmpdir" && uudecode "$file" 2>/dev/null) || { echo "armor-check: $file FAIL (decode error)"; return 1; }
                decoded=$(ls "$tmpdir"/* 2>/dev/null | head -1)
                if [ -n "$decoded" ]; then
                    size=$(wc -c < "$decoded" | tr -d ' ')
                    echo "armor-check: $file OK (round-trip $size bytes)"
                    return 0
                else
                    echo "armor-check: $file FAIL (no output)"
                    return 1
                fi
            else
                echo "armor-check: $file SKIP (uudecode not found)"
                return 2
            fi
            ;;
        b64)
            if command -v b64decode >/dev/null 2>&1; then
                (cd "$tmpdir" && b64decode "$file" 2>/dev/null) || { echo "armor-check: $file FAIL (decode error)"; return 1; }
                decoded=$(ls "$tmpdir"/* 2>/dev/null | head -1)
                if [ -n "$decoded" ]; then
                    size=$(wc -c < "$decoded" | tr -d ' ')
                    echo "armor-check: $file OK (round-trip $size bytes)"
                    return 0
                else
                    echo "armor-check: $file FAIL (no output)"
                    return 1
                fi
            else
                echo "armor-check: $file SKIP (b64decode not found)"
                return 2
            fi
            ;;
        a85)
            if command -v python3 >/dev/null 2>&1; then
                python3 -c "
import base64, sys
with open('$file', 'r') as f:
    encoded = f.read().strip()
try:
    decoded = base64.a85decode(encoded, adobe=True)
    sys.stdout.buffer.write(decoded)
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
    sys.exit(1)
" > "$tmpdir/decoded" 2>/dev/null || { echo "armor-check: $file FAIL (decode error)"; return 1; }
                size=$(wc -c < "$tmpdir/decoded" | tr -d ' ')
                echo "armor-check: $file OK (round-trip $size bytes)"
                return 0
            else
                echo "armor-check: $file SKIP (python3 not found)"
                return 2
            fi
            ;;
        hex)
            if command -v xxd >/dev/null 2>&1; then
                xxd -r "$file" "$tmpdir/decoded" 2>/dev/null || { echo "armor-check: $file FAIL (decode error)"; return 1; }
                size=$(wc -c < "$tmpdir/decoded" | tr -d ' ')
                echo "armor-check: $file OK (round-trip $size bytes)"
                return 0
            else
                echo "armor-check: $file SKIP (xxd not found)"
                return 2
            fi
            ;;
        xbm|xpm)
            # XBM/XPM are C source - validate syntax
            if grep -q "static.*char\|static.*unsigned" "$file" 2>/dev/null; then
                lines=$(wc -l < "$file" | tr -d ' ')
                echo "armor-check: $file OK (valid C syntax, $lines lines)"
                return 0
            else
                echo "armor-check: $file FAIL (invalid format)"
                return 1
            fi
            ;;
        h)
            # C header from xxd -i
            if grep -q "unsigned char\|unsigned int" "$file" 2>/dev/null; then
                lines=$(wc -l < "$file" | tr -d ' ')
                echo "armor-check: $file OK (valid C include, $lines lines)"
                return 0
            else
                echo "armor-check: $file FAIL (invalid format)"
                return 1
            fi
            ;;
        md)
            # Skip README files
            echo "armor-check: $file SKIP (documentation)"
            return 2
            ;;
        *)
            echo "armor-check: $file SKIP (unknown format .$ext)"
            return 2
            ;;
    esac
}

if [ $# -eq 0 ]; then
    echo "Usage: armor-check [file...]"
    echo "Validates binary-in-text encoded files round-trip correctly."
    exit 0
fi

for file in "$@"; do
    if [ ! -f "$file" ]; then
        echo "armor-check: $file FAIL (not found)"
        FAIL=$((FAIL + 1))
        continue
    fi

    # Convert to absolute path
    file=$(cd "$(dirname "$file")" && pwd)/$(basename "$file")

    result=0
    check_file "$file" || result=$?

    case $result in
        0) PASS=$((PASS + 1)) ;;
        1) FAIL=$((FAIL + 1)) ;;
        2) SKIP=$((SKIP + 1)) ;;
    esac
done

echo ""
echo "Summary: $PASS passed, $FAIL failed, $SKIP skipped"

if [ $FAIL -gt 0 ]; then
    exit 1
fi
exit 0
